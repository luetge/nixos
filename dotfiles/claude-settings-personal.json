{
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/memory-prompt-hook.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/precompact-hook.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/postcompact-hook.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}

{
  "model": "claude-opus-4-8",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/memory-prompt-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/precompact-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-personal/hooks/postcompact-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "last30days@last30days-skill": true,
    "stripe@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(jj log:*)",
      "Bash(jj diff:*)",
      "Bash(jj st:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix flake show:*)",
      "Bash(nix eval:*)",
      "Bash(nix build:*)",
      "Bash(nix fmt:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo nextest run:*)",
      "Bash(cargo test:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(ty check:*)",
      "Bash(uv run pytest:*)"
    ]
  },
  "effortLevel": "high",
  "tui": "fullscreen"
}
